# DELETE
# ----------------------------------------

### DELETE /workoutTemplates/:id - Eliminar template
DELETE {{baseUrl}}/workoutTemplates/c8928807-9322-4e74-8d1b-da1a88794044 HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}

### DELETE /workoutTemplates/:id - Error: ID inexistente (404)
DELETE {{baseUrl}}/workoutTemplates/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}

# ----------------------------------------
# DUPLICATE
# ----------------------------------------

### POST /workoutTemplates/:id/duplicate - Duplicar template (copia sets también)
POST {{baseUrl}}/workoutTemplates/d2c31fd5-5720-459c-964b-17f9cad150a9/duplicate HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}

### POST /workoutTemplates/:id/duplicate - Error: ID inexistente (404)
POST {{baseUrl}}/workoutTemplates/00000000-0000-0000-0000-000000000000/duplicate HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}

# ----------------------------------------
# FAVORITE
# ----------------------------------------

### PATCH /workoutTemplates/:id/favorite - Toggle favorito
PATCH {{baseUrl}}/workoutTemplates/d2c31fd5-5720-459c-964b-17f9cad150a9/favorite HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}

### PATCH /workoutTemplates/:id/favorite - Error: ID inexistente (404)
PATCH {{baseUrl}}/workoutTemplates/00000000-0000-0000-0000-000000000000/favorite HTTP/1.1
Authorization: Bearer {{userToken.response.body.data.accessToken}}
